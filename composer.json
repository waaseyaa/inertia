{
    "name": "waaseyaa/inertia",
    "description": "Server-side Inertia.js v3 protocol adapter for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        { "type": "path", "url": "../foundation" }
    ],
    "require": {
        "php": ">=8.4",
        "waaseyaa/foundation": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": { "Waaseyaa\\Inertia\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Waaseyaa\\Inertia\\Tests\\": "tests/" }
    },
    "extra": {
        "waaseyaa": {
            "layer": 6,
            "providers": ["Waaseyaa\\Inertia\\InertiaServiceProvider"]
        },
        "branch-alias": { "dev-main": "0.1.x-dev" }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
